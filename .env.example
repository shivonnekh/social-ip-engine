# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ChatDaddy WhatsApp IM API
# Use EITHER api token OR refresh token (not both)
CHATDADDY_API_TOKEN=apit_...
# CHATDADDY_REFRESH_TOKEN=...
CHATDADDY_ACCOUNT_ID=
CHATDADDY_WEBHOOK_SECRET=

# Server
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/jessica.db

# Tracing
TRACE_DIR=./traces
TRACE_RETENTION_DAYS=30

# WhatsApp bubble timing (tune for natural feel)
WA_BUBBLE_DELAY_MIN=2.5
WA_BUBBLE_DELAY_MAX=6.0
WA_BUBBLE_DELAY_THINK_BASE=1.8
WA_BUBBLE_DELAY_PER_CHAR=0.020
WA_BUBBLE_DELAY_JITTER=0.6

# Polling fallback
WA_POLL_ENABLED=true
WA_POLL_INTERVAL_S=5

# Order WhatsApp (心宜中醫)
ORDER_WHATSAPP=+85252417448
