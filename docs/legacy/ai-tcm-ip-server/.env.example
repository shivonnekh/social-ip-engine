# Copy to server/.env and fill in. server/.env is gitignored.

# Any random string YOU invent. Paste the SAME value into the Meta dashboard
# when you register the webhook callback URL.
META_VERIFY_TOKEN=chenzhiqing_tcm_2026_change_me

# From Meta App dashboard → App Settings → Basic → App Secret.
# Used to verify the X-Hub-Signature-256 on incoming events.
META_APP_SECRET=

# Optional account ids for log routing. These are not access tokens.
# Fill these once each IG business account / Facebook Page is connected.
CHLOE_IG_ID=
CHLOE_PAGE_ID=
JACKIE_IG_ID=
JACKIE_PAGE_ID=

# Access tokens with comment-management + messaging permission, per brand.
# Needed before ANY auto-reply works. (IG token preferred; Page token fallback.)
JACKIE_PAGE_ACCESS_TOKEN=
JACKIE_IG_ACCESS_TOKEN=
CHLOE_PAGE_ACCESS_TOKEN=
CHLOE_IG_ACCESS_TOKEN=

# Auto-reply behavior:
#   Default = keyword-driven. A comment containing a CTA keyword (migraine, tonsil,
#   gut, ...) triggers a private DM with that concept's First DM, read from
#   server/dm_map.json (regenerate with: python3 scripts/export_dm_map.py).
# Static fallback strings, used ONLY when no keyword matches AND REPLY_TO_ALL_COMMENTS=true:
JACKIE_COMMENT_REPLY=Sent you the details. Check your DM 📩
JACKIE_PRIVATE_REPLY=Thanks for commenting. I sent you the details here.
# "true" = reply to every comment (legacy). Empty = keyword-only (recommended).
REPLY_TO_ALL_COMMENTS=

# Public base URL of this server (no trailing slash).
# Set after first Render deploy (e.g. https://ai-tcm-ip.onrender.com).
# Used to build infographic image URLs for DMs.
WEBHOOK_BASE_URL=
